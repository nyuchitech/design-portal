{
  "name": "@nyuchi/design-cli",
  "version": "0.1.0",
  "description": "Bootstrap a Nyuchi Design app — install components from the registry and skills for AI agents.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://design.nyuchi.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyuchi/design-portal.git",
    "directory": "packages/design-cli"
  },
  "bugs": {
    "url": "https://github.com/nyuchi/design-portal/issues"
  },
  "keywords": [
    "nyuchi",
    "design-system",
    "shadcn",
    "registry",
    "cli",
    "scaffold",
    "ai",
    "skills",
    "claude-code"
  ],
  "author": "Nyuchi Africa (PVT) Ltd",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "nyuchi-design": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "dist/",
    "templates/",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  }
}
